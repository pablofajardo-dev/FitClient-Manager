<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir seguimiento"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etSeguimientoClienteId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ID del cliente"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etSeguimientoFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha: 22/05/2026"
            android:inputType="date"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etSeguimientoPeso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Peso: 78.5"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etSeguimientoObservaciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Observaciones del seguimiento"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:gravity="top"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGuardarSeguimiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar seguimiento"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnVolverSeguimiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver" />

    </LinearLayout>

</ScrollView>