<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF3F5"
    android:fitsSystemWindows="true"
    android:clipToPadding="false"
    android:paddingTop="16dp"
    android:paddingBottom="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_main_title"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FitClient Manager"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#24303A"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MVP local para la gestión de entrenamiento personal"
                android:textSize="15sp"
                android:textColor="#5E6B75"
                android:gravity="center" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecciona una sección"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#24303A"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clientes"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#3F3272"
            android:background="@drawable/bg_section_title"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnNuevoCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir cliente"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btnClientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver clientes"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp"/>

        <Button
            android:id="@+id/btnEditarEliminarCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar / eliminar cliente"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="24dp"
            android:elevation="3dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rutinas"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#3F3272"
            android:background="@drawable/bg_section_title"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnNuevaRutina"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir rutina"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btnVerRutinas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver todas las rutinas"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btnRutinasPorCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver rutinas por cliente"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="24dp"
            android:elevation="3dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seguimientos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#3F3272"
            android:background="@drawable/bg_section_title"
            android:padding="14dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp" />

        <Button
            android:id="@+id/btnNuevoSeguimiento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Añadir seguimiento"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btnVerSeguimientos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver todos los seguimientos"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="10dp"
            android:elevation="3dp" />

        <Button
            android:id="@+id/btnSeguimientosPorCliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver seguimientos por cliente"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_soft_button"
            android:padding="14dp"
            android:layout_marginBottom="32dp"
            android:elevation="3dp" />

    </LinearLayout>

</ScrollView>